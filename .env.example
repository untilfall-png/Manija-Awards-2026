# Firebase Configuration
# Replace with your actual Firebase project credentials
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Admin Panel Configuration
# Default Admin Password (ONLY FOR DEVELOPMENT)
# Access admin panel at: /admin
# Default password: ManijAdmin2026
# IMPORTANT: Change NEXT_PUBLIC_ADMIN_PASSWORD before deploying.
NEXT_PUBLIC_ADMIN_PASSWORD=ManijAdmin2026

# Security Notes:
# - CHANGE the NEXT_PUBLIC_ADMIN_PASSWORD immediately after initial setup
# - Store the new admin password in a secure password manager
# - Do NOT commit .env.local to version control
# - All NEXT_PUBLIC_* variables are exposed to the browser (they are public)
