rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Voters collection - allow read/write for authenticated users
    match /voters/{voterId} {
      allow read, write: if request.auth != null;
      // Allow creation for new voters
      allow create: if true;
    }

    // Votes collection - allow read/write for authenticated users
    match /votes/{voteId} {
      allow read: if true; // Allow reading votes for live results
      allow write: if request.auth != null &&
                   // Ensure voter hasn't already voted for this category
                   !exists(/databases/$(database)/documents/votes/$(request.auth.uid + '_' + request.resource.data.categoryId));
    }

    // Categories collection (if we add it later)
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if false; // Only admin can modify categories
    }
  }
}