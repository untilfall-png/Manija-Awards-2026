rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Voters collection - allow creation without auth
    match /voters/{voterId} {
      allow create: if true; // Allow unauthenticated voter creation
      allow read, write: if true; // Allow read/write for voting
    }

    // Votes collection - allow read/write without auth
    match /votes/{voteId} {
      allow read, write: if true; // Allow voting without authentication
    }

    // Categories collection
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if false; // Only admin can modify categories
    }
  }
}